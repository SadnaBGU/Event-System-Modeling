# Mocks were removed; the dev server proxies /api to the real Spring Boot backend on :8080.
VITE_USE_MOCKS=false

# Real backend URL (proxied by Vite to http://localhost:8080).
VITE_API_BASE_URL=/api

# Notifications WebSocket: STOMP over SockJS, served at /api/notifications/stream.
# The backend pushes per-user messages on /user/queue/notifications.
VITE_WS_URL=/api/notifications/stream
VITE_WS_DESTINATION=/user/queue/notifications
VITE_WS_TRANSPORT=stomp
