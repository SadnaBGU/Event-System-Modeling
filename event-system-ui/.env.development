# Default to mocked WAF during P0/P1 development.
# Flip to false (or remove) once we wire to the real WAF dev server.
VITE_USE_MOCKS=true

# Real backend URL goes here in non-mocked mode.
VITE_API_BASE_URL=/api

# WebSocket destination for notifications.
VITE_WS_URL=/api/notifications/stream
VITE_WS_DESTINATION=/user/queue/notifications

# Notification transport. 'raw' against the mock WS server in dev,
# 'stomp' against the real WAF backend (STOMP over SockJS).
VITE_WS_TRANSPORT=raw
