# Cloud Postgres settings for `.\up.ps1 -Target cloud`.
# Copy this file to `.env.cloud` (gitignored) and fill in real values.
# KEY=VALUE per line; quotes optional. Lines starting with # are ignored.

# --- GCP Cloud SQL Postgres (db is hardcoded to eventsystem_db, sslmode=require) ---
DB_IP=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=

# --- Security (>= 32 bytes) ---
JWT_SECRET=

# --- Bootstrapped site admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Site
ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_DOB=1990-01-01
