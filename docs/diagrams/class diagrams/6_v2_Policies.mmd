classDiagram
    direction TB

%% ══════════════════════════════════════════
%% Policy domain:
%% Updated Policy Domain design for V2
%% Minimal domain style - no getters/setters, no application services
%% ══════════════════════════════════════════

    namespace Domain_Policy {

        class PurchasePolicy
        class PurchasePolicyId


        class DiscountPolicy
        class Discount
        class PurchaseContext

        class DiscountSummary


        class PolicyValidationResult
        class PolicyScope

        class PolicyBuilder
        class PolicyConflictDetector
        
        class DiscountPolicyId

        class IPolicy
        class IBasicPolicy
        class ICompositePolicy
        class ConcreteBasicPolicy
        class ConcreteCompositePolicy
        class PolicyType


    }

%% ══════════════════════════════════════════
%% AGGREGATE PurchasePolicy:
%% Defines purchase restrictions for company/event scope.
%% Evaluates purchase context and returns PolicyValidationResult.
%% ══════════════════════════════════════════

    class PurchasePolicy:::aggregate {
        <<Aggregate Root>>
        - PurchasePolicyId id
        - String policyName
        - CompanyId companyId
        - PolicyScope scope
        - IPolicy policy
        + evaluate(PurchaseContext) PolicyValidationResult
        + requirePurchasePolicy(PurchaseContext) void
        + isPurchaseAllowedInContext(PurchaseContext) boolean
        + setNameTo(String) void
        + setScopeTo(PolicyScope) void
        + setCompanyWide() void
        + deactivateCompanyWide() void
        + activateForEvent(EventId) void
        + deactivateForEvent(EventId) void
    }

%% ══════════════════════════════════════════
%% AGGREGATE DiscountPolicy:
%% Defines percentage-based discounts for company/event scope.
%% Supports MAX mode or SUM/stacking mode.
%% ══════════════════════════════════════════

    class DiscountPolicy:::aggregate {
        <<Aggregate Root>>
        - DiscountPolicyId id
        - CompanyId companyId
        - PolicyScope scope
        - List~Discount~ discounts
        - boolean stackable
        - boolean active
        + activate() void
        + deactivate() void
        + changeScope(PolicyScope) void
        + setCompanyWide() void
        + deactivateCompanyWide() void
        + activateForEvent(EventId) void
        + deactivateForEvent(EventId) void
        + clearAllEventsFromScope() void
        + allowStacking() void
        + disallowStacking() void
        + addDiscount(Discount) void
        + appliesTo(PurchaseContext) boolean
        + isPurchaseEligibleForDiscount(PurchaseContext) boolean
        + getFullDiscountSummary(PurchaseContext, Money) DiscountSummary
        + getFullDiscountPercent(PurchaseContext) BigDecimal
        + generateDiscountSnapshot(PurchaseContext, Money) DiscountSnapshot
        + generateDiscountSnapshot(DiscountSummary, Money) DiscountSnapshot
    }

%% ══════════════════════════════════════════
%% VALUE OBJECTS / ENTITIES
%% ══════════════════════════════════════════

    class PurchasePolicyId:::idValueObject {
        <<ID - Value Object>>
    }

    class DiscountPolicyId:::idValueObject {
        <<ID - Value Object>>
    }

    class PolicyScope:::valueObject {
        <<Value Object>>
        - boolean companyWide
        - Set~EventId~ eventIds
        + appliesTo(EventId) boolean
        + isCompanyWide() boolean
        + isRelatedToEvents() boolean
        + isScopedToEventsOrCompany() boolean
    }

    class PurchaseContext:::valueObject {
        <<Value Object>>
        - EventId eventId
        - CompanyId companyId
        - List~ZoneId~ zonesOfEachEventTicket
        - LocalDate buyerBirthDate
        - LocalDate purchaseDate
        - String discountCode
        + ticketCount() int
        + withCode(String) PurchaseContext
        + withPurchaseDate(LocalDate) PurchaseContext
        + fromPurchaseInfo(...) PurchaseContext
    }

    class PolicyValidationResult:::valueObject {
        <<Value Object>>
        - boolean valid
        - String reason
        + success() PolicyValidationResult
        + failure(String) PolicyValidationResult
        + failureReason() Optional~String~
    }

    class Discount:::entity {
        <<Entity>>
        - String discountName
        - BigDecimal discountPercent
        - IPolicy discountPolicy
        + validateDiscount(PurchaseContext) boolean
        + getValidDiscountAmount(PurchaseContext) BigDecimal
        + GeneralDiscount(String, BigDecimal) Discount
    }

    class DiscountSummary:::valueObject {
        <<Value Object>>
        - List~String~ appliedDiscountsNames
        - List~BigDecimal~ appliedDiscountsPercents
        - List~BigDecimal~ actualDiscountAmount
        - BigDecimal totalDiscount
        + getSpecificDiscountInfo(int) String
        + getSpecificDiscountInfo(String) String
        + isDiscountCappedAt100() boolean
        + NoDiscountSummary() DiscountSummary
        + ReplaceActualAmounts(List~BigDecimal~, BigDecimal) DiscountSummary
    }

    class PolicyType:::valueObject {
        <<Enum>>
        ALWAYS_TRUE
        NEVER_ALLOW
        MIN_TICKETS
        MAX_TICKETS
        MIN_AGE
        AFTER_DATE
        UNTIL_DATE
        CODE
        NO_SINGLE_EMPTY_SEAT
        AND
        OR
        ZONE_SPECIFIC_0_PASS
        ZONE_SPECIFIC_0_FAIL
        UNKNOWN
    }

%% ══════════════════════════════════════════
%% POLICY STRATEGY + COMPOSITE MODEL
%% IPolicy is the strategy abstraction.
%% Basic policies are leaf strategies.
%% Composite policies combine other policies.
%% ══════════════════════════════════════════

    class IPolicy:::interface {
        <<interface>>
        + type() PolicyType
        + evaluate(PurchaseContext) PolicyValidationResult
        + validate(PurchaseContext) boolean
        + require(PurchaseContext) void
        + isValidPolicy() boolean
        + isComposite() boolean
    }

    class IBasicPolicy:::interface {
        <<interface>>
    }

    class ICompositePolicy:::interface {
        <<interface>>
        + children() List~IPolicy~
    }

    class ConcreteBasicPolicy:::implementation {
        <<Basic Policy Implementations>>
        AlwaysTruePolicy
        NeverAllowPolicy
        MinAgePolicy
        MinTicketPolicy
        MaxTicketPolicy
        AfterDatePolicy
        UntilDatePolicy
        CodePolicy
        NoSingleEmptySeatPolicy
    }

    class ConcreteCompositePolicy:::implementation {
        <<Composite Policy Implementations>>
        AndPolicy
        OrPolicy
        ZoneSpecificPolicy
    }

    class PolicyBuilder:::factory {
        <<Factory>>
        - List~IPolicy~ policies
        + start() PolicyBuilder
        + minAge(int) PolicyBuilder
        + minTickets(int) PolicyBuilder
        + maxTickets(int) PolicyBuilder
        + beforeDate(LocalDate) PolicyBuilder
        + afterDate(LocalDate) PolicyBuilder
        + code(String) PolicyBuilder
        + add(IPolicy) PolicyBuilder
        + build() IPolicy
        + and(IPolicy...) IPolicy
        + or(IPolicy...) IPolicy
        + PolicyRestrictToZones(Set~ZoneId~, IPolicy) IPolicy
        + PolicyRequireFromZones(Set~ZoneId~, IPolicy) IPolicy
    }

    class PolicyConflictDetector:::utility {
        <<Domain Utility>>
        + detectInnerConflicts(IPolicy) PolicyValidationResult
        + detectConflictBetween(IPolicy, IPolicy) PolicyValidationResult
        + requireValidPolicy(IPolicy) void
        + requireValidPolicy(List~IPolicy~) void
    }

%% ══════════════════════════════════════════
%% CORE DOMAIN RELATIONS
%% ══════════════════════════════════════════

    PurchasePolicy "1" *-- "1" PurchasePolicyId
    PurchasePolicy "1" *-- "1" PolicyScope
    PurchasePolicy "1" -->"1" IPolicy : purchase condition (strategy)
    PurchasePolicy ..> PurchaseContext
    PurchasePolicy ..> PolicyValidationResult
    PurchasePolicy ..> PolicyConflictDetector

    DiscountPolicy "1" *-- "1" DiscountPolicyId
    DiscountPolicy "1" *-- "1" PolicyScope
    DiscountPolicy "1" *-- "0..n" Discount
    DiscountPolicy ..> PurchaseContext
    DiscountPolicy ..> DiscountSummary
    DiscountPolicy ..> DiscountSnapshot
    DiscountPolicy ..> Money
    DiscountPolicy ..> PolicyConflictDetector

    Discount "1" --> "1" IPolicy : discount condition (strategy)
    Discount ..> PurchaseContext

    PolicyBuilder "1" o-- "0..n" IPolicy
    PolicyBuilder ..> IPolicy : builds

    PolicyConflictDetector ..> IPolicy
    PolicyConflictDetector ..> ICompositePolicy
    PolicyConflictDetector ..> PolicyValidationResult
    PolicyConflictDetector ..> PolicyType

    IPolicy --> PolicyType
    IPolicy ..> PurchaseContext
    IPolicy ..> PolicyValidationResult

    IPolicy <|-- IBasicPolicy
    IPolicy <|-- ICompositePolicy

    IBasicPolicy <|.. ConcreteBasicPolicy

    ICompositePolicy "1" o-- "1..n" IPolicy : children(composition)
    ICompositePolicy <|.. ConcreteCompositePolicy

%% ══════════════════════════════════════════
%% EXTERNAL DOMAIN REFERENCES
%% Only typed IDs / value objects are referenced across bounded contexts.
%% ══════════════════════════════════════════

    namespace Domain_Company {
        class CompanyId:::external
    }

    namespace Domain_Event {
        class EventId:::external
    }

    namespace Domain_Zone {
        class ZoneId:::external
    }

    namespace Domain_Order {
        class Money:::external
    }

    namespace Domain_PurchaseRecord {
        class DiscountSnapshot:::external
    }

    PurchasePolicy --> CompanyId : owner company
    DiscountPolicy --> CompanyId : owner company

    PolicyScope "1" --> "0..n" EventId : events affected by policy

    PurchaseContext --> CompanyId : company of event
    PurchaseContext --> EventId : event of purchase
    PurchaseContext --> ZoneId : ticket zones

    PolicyBuilder ..> ZoneId : zone-specific rules

%% ══════════════════════════════════════════
%% PERSISTENCE BOUNDARY / REPOSITORIES
%% ══════════════════════════════════════════

    namespace Persistence_Boundary {
        class PurchasePolicyRepository:::repository
        class DiscountPolicyRepository:::repository
    }

    class PurchasePolicyRepository {
        <<Repository>>
    }

    class DiscountPolicyRepository {
        <<Repository>>
    }

    PurchasePolicyRepository ..> PurchasePolicy : manages persistence
    DiscountPolicyRepository ..> DiscountPolicy : manages persistence

