%% =====================================================================
%% Event System — V3 System Overview  (SRS-aligned domain class diagram)
%%
%% High-level, "white-box" STRUCTURAL view: domain entities and their
%% relationships ONLY. By design this diagram carries NO attributes and
%% NO methods — it expresses business structure, not implementation.
%%
%% UML notation used:
%%   <|--   generalization / inheritance
%%   *--    composition (part cannot exist without the whole)
%%   o--    aggregation (whole references parts that may live on)
%%   -->    directed association
%%   --     plain association
%%   "n"    multiplicities (1, 0..1, 0..*, 1..*)
%% =====================================================================

%% ───────────────────────── Platform Root ─────────────────────────
    class Platform:::system {
        <<system>>
    }

%% ───────────────────────── Users & Roles ─────────────────────────
    class User:::actor {
        <<abstract>>
    }
    class Guest:::actor
    class Member:::actor
    class SystemAdmin:::actor

    class Producer:::role {
        <<abstract>>
    }
    class Founder:::role
    class Owner:::role
    class Manager:::role
    class Permission:::enumr {
        <<enumeration>>
    }

%% ──────────────────────── Company & Catalog ──────────────────────
    class ProductionCompany:::aggregate
    class Event:::aggregate
    class Show:::entity

%% ──────────────────────── Venue & Seating ────────────────────────
    class SeatingMap:::entity
    class PricingZone:::entity
    class Space:::entity {
        <<abstract>>
    }
    class DesignatedSeat:::entity
    class OpenSpaceArea:::entity

%% ─────────────────────── Ticketing & Orders ──────────────────────
    class ActiveOrder:::aggregate
    class Ticket:::entity

%% ──────────────────────────── Policies ───────────────────────────
    class PurchasePolicy:::policy
    class DiscountPolicy:::policy
    class DiscountType:::policy {
        <<abstract>>
    }
    class VisibleDiscount:::policy
    class ConditionalDiscount:::policy
    class CouponCode:::policy

%% ─────────────────────── External Systems ────────────────────────
    class PaymentGateway:::external {
        <<external>>
    }
    class TicketIssuingService:::external {
        <<external>>
    }

%% ─────────────────────── Traffic Control ─────────────────────────
    class VirtualQueue:::infra

%% =====================================================================
%% RELATIONSHIPS
%% =====================================================================

%% --- User hierarchy: Guest & Member are users; an Admin is a Member ---
    User <|-- Guest
    User <|-- Member
    Member <|-- SystemAdmin

%% --- Producer is the general term for the three company roles ---
    Producer <|-- Founder
    Producer <|-- Owner
    Producer <|-- Manager

%% --- A Member plays context-dependent producer roles across companies ---
    Member "1" -- "0..*" Producer : plays

%% --- Ownership forms a strict, acyclic appointment tree ---
    Owner "0..1" --> "0..*" Owner : appoints
    Owner "1" --> "0..*" Manager : appoints
    Manager "1" --> "1..*" Permission : granted

%% --- Platform aggregates the registered population and the catalog owners ---
    Platform "1" *-- "0..*" Member : registers
    Platform "1" *-- "0..*" ProductionCompany : hosts
    Platform "1" -- "1..*" SystemAdmin : administered by

%% --- Company, ownership and catalog ---
    ProductionCompany "1" -- "1" Founder : founded by
    ProductionCompany "1" -- "1..*" Owner : owned by
    ProductionCompany "1" -- "0..*" Manager : managed by
    ProductionCompany "1" *-- "0..*" Event : catalog

%% --- Each producer role is scoped to exactly one company context ---
    Producer "0..*" --> "1" ProductionCompany : within

%% --- Event structure: performances and the seating layout ---
    Event "1" *-- "1..*" Show : performances
    Event "1" *-- "1" SeatingMap : layout
    SeatingMap "1" *-- "1..*" PricingZone : zones
    PricingZone "1" *-- "1..*" Space : spaces
    Space <|-- DesignatedSeat
    Space <|-- OpenSpaceArea

%% --- Reservation: an order belongs to one buyer and locks tickets ---
    ActiveOrder "0..*" --> "1" User : buyer
    ActiveOrder "0..*" --> "1" Event : for
    ActiveOrder "1" o-- "1..*" Ticket : reserves
    Ticket "0..*" --> "1" Show : for
    Ticket "0..*" --> "1" Space : locks

%% --- Policies bind to both the company and each of its events ---
    ProductionCompany "1" --> "1" PurchasePolicy : rules
    ProductionCompany "1" --> "1" DiscountPolicy : discounts
    Event "1" --> "1" PurchasePolicy : rules
    Event "1" --> "1" DiscountPolicy : discounts

%% --- Discount composition ---
    DiscountPolicy "1" *-- "0..*" DiscountType : composes
    DiscountType <|-- VisibleDiscount
    DiscountType <|-- ConditionalDiscount
    DiscountType <|-- CouponCode

%% --- External services: 1-to-many connections from the platform ---
    Platform "1" --> "1..*" PaymentGateway : billing and refunds
    Platform "1" --> "1..*" TicketIssuingService : digital barcodes

%% --- Virtual queue throttles traffic to a busy event ---
    Event "1" -- "0..1" VirtualQueue : throttled by

%% =====================================================================
%% CONSTRAINT NOTES
%% =====================================================================
    note for SystemAdmin "A SystemAdmin is always a registered Member."
    note for Producer "Producer is the general role a Member plays inside a ProductionCompany: Founder, Owner, or Manager."
    note for Owner "Ownership is a strict acyclic tree: every Owner has at most one appointer (Appointer); the Founder is the root and has none. An Owner assigns and may alter the Permissions of the Managers it appoints."
    note for ProductionCompany "A non-closed ProductionCompany must always have at least one Owner."
    note for ActiveOrder "A buyer (Guest or Member) may hold at most one ActiveOrder per Event at any given moment. Reserved Tickets are temporarily locked from the Event inventory."

