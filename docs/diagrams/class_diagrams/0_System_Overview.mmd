flowchart TB

    %% ============================================
    %% COLOR DEFINITIONS
    %% ============================================
    classDef appSvc fill:#4A90D9,stroke:#2C5F8A,color:#fff,font-weight:bold
    classDef port fill:#F5A623,stroke:#C47D1A,color:#fff,font-weight:bold
    classDef aggRoot fill:#7ED321,stroke:#5A9A18,color:#fff,font-weight:bold
    classDef internal fill:#B8E986,stroke:#7CB342,color:#333
    classDef valueObj fill:#D0A9F5,stroke:#9B59B6,color:#333
    classDef policy fill:#F8E71C,stroke:#C5B200,color:#333,font-weight:bold
    classDef infra fill:#E07070,stroke:#C0392B,color:#fff,font-weight:bold
    classDef repo fill:#90CAF9,stroke:#1565C0,color:#1a3a5c,font-style:italic

    %% ============================================
    %% APPLICATION LAYER
    %% Ordered left-to-right to align with aggregates below
    %% ============================================
    subgraph APP["🔵 APPLICATION LAYER — Services"]
        direction LR

        subgraph UserSession["User & Session"]
            AuthSvc["AuthService"]
            MemberSvc["MemberService"]
            AdminSvc["AdminService"]
        end

        subgraph CompanyMgmt["Company Management"]
            CompanySvc["CompanyService"]
            ApptSvc["AppointmentService"]
            EvtMgmtSvc["EventMgmtService"]
            PolicySvc["PolicyMgmtService"]
            ReportSvc["ReportService"]
        end

        subgraph PurchaseFlow["Purchase Flow"]
            SearchSvc["SearchService"]
            OrderSvc["OrderService"]
            CheckoutSvc["CheckoutSaga"]
            QueueSvc["QueueService"]
            LotterySvc["LotteryService"]
        end

        subgraph Notifications["Notifications & History"]
            NotifSvc["NotificationService"]
            HistorySvc["PurchaseHistoryService"]
        end
    end

    %% ============================================
    %% PORT INTERFACES
    %% ============================================
    subgraph PORTS["🟠 EXTERNAL SERVICE INTERFACES"]
        direction LR
        PayGw["PaymentGateway"]
        IssGw["IssuanceGateway"]
        NotifCh["NotificationChannel"]
    end

    %% ============================================
    %% DOMAIN LAYER — AGGREGATES
    %% Ordered left-to-right matching services above
    %% ============================================
    subgraph DOMAIN["🟢 DOMAIN LAYER"]
        direction LR

        subgraph Col1[" "]
            subgraph AGG_PLATFORM["⬡ Platform"]
                Platform["Platform"]
                PlatformRepo["PlatformRepository"]
            end

            subgraph AGG_MEMBER["⬡ Member"]
                Member["Member"]
                Notif["Notification"]
                MemberRepo["MemberRepository"]
            end
        end

        subgraph Col2[" "]
            subgraph AGG_COMPANY["⬡ ProductionCompany"]
                Company["ProductionCompany"]
                AppTree["AppointmentTree"]
                ONode["OwnerNode"]
                MNode["ManagerNode"]
                CompanyRepo["CompanyRepository"]
            end

            subgraph AGG_EVENT["⬡ Event"]
                Event["Event"]
                VMap["VenueMap"]
                EventRepo["EventRepository"]
            end

            subgraph AGG_ZONE["⬡ Zone"]
                Zone["Zone"]
                RowE["Row"]
                SeatE["Seat"]
                ZoneRepo["ZoneRepository"]
            end
        end

        subgraph Col3[" "]
            subgraph AGG_ORDER["⬡ ActiveOrder"]
                Order["ActiveOrder"]
                OItem["OrderItem"]
                OrderRepo["OrderRepository"]
            end

            subgraph AGG_QUEUE["⬡ VirtualQueue"]
                VQueue["VirtualQueue"]
                QEntry["QueueEntry"]
                AToken["AdmissionToken"]
                QueueRepo["QueueRepository"]
            end

            subgraph AGG_LOTTERY["⬡ Lottery"]
                Lottery["Lottery"]
                LWinner["LotteryWinner"]
                LotteryRepo["LotteryRepository"]
            end

            subgraph AGG_PURCHASE["⬡ PurchaseRecord"]
                PurchRec["PurchaseRecord"]
                PItem["PurchasedItem"]
                PurchaseRepo["PurchaseRecordRepository"]
            end
        end

        subgraph DomainServices["Domain Services"]
            OFactory["OrderFactory"]
        end

        subgraph Policies["Policies — Strategy Pattern"]
            direction LR
            PPol["PurchasePolicy"]
            DPol["DiscountPolicy"]
            DRule["DiscountRule"]
        end

        subgraph ValueObjs["Value Objects"]
            direction LR
            BuyerRef["BuyerReference"]
            BuyerSnap["BuyerSnapshot"]
            EvtSnap["EventSnapshot"]
            DiscSnap["DiscountSnapshot"]
            MoneyVO["Money"]
        end
    end

    %% ============================================
    %% INFRASTRUCTURE LAYER
    %% ============================================
    subgraph INFRA["🔴 INFRASTRUCTURE LAYER"]
        direction LR
        DBRepos["DB Repositories"]
        PayAdapt["Payment Adapters"]
        IssAdapt["Issuance Adapters"]
        NotifAdapt["Notification Adapters"]
    end

    %% ============================================
    %% LAYER CONNECTIONS
    %% ============================================
    APP -->|"uses"| PORTS
    PORTS -->|"implemented by"| INFRA
    INFRA -->|"persists"| DOMAIN

    %% ============================================
    %% SERVICE → AGGREGATE CONNECTIONS
    %% Grouped by column to minimize crossings
    %% Color-coded per service for traceability
    %% ============================================

    %% Column 1: User/Admin → Platform, Member
    AuthSvc --> Member
    MemberSvc --> Member
    AdminSvc --> Platform
    NotifSvc --> Member

    %% Column 2: Company/Event → Company, Event, Zone
    CompanySvc --> Company
    ApptSvc --> Company
    ApptSvc --> Member
    EvtMgmtSvc --> Event
    EvtMgmtSvc --> Zone
    PolicySvc --> Event

    %% Column 3: Purchase → Order, Queue, Lottery, PurchaseRecord, Zone
    SearchSvc --> Event
    SearchSvc --> Zone
    OrderSvc --> Order
    OrderSvc --> Zone
    CheckoutSvc --> Order
    CheckoutSvc --> Zone
    CheckoutSvc --> PurchRec
    CheckoutSvc --> VQueue
    QueueSvc --> VQueue
    LotterySvc --> Lottery
    HistorySvc --> PurchRec
    ReportSvc --> PurchRec

    %% ============================================
    %% LINK STYLES — color per service
    %% Links 0-2: layer connections (gray)
    %% Links 3+: service→aggregate (colored per service)
    %% ============================================
    linkStyle 0 stroke:#999,stroke-width:2px
    linkStyle 1 stroke:#999,stroke-width:2px
    linkStyle 2 stroke:#999,stroke-width:2px
    %% AuthSvc (blue)
    linkStyle 3 stroke:#1E88E5,stroke-width:2px
    %% MemberSvc (deep purple)
    linkStyle 4 stroke:#5E35B1,stroke-width:2px
    %% AdminSvc (brown)
    linkStyle 5 stroke:#6D4C41,stroke-width:2px
    %% NotifSvc (teal)
    linkStyle 6 stroke:#00897B,stroke-width:2px
    %% CompanySvc (deep orange)
    linkStyle 7 stroke:#F4511E,stroke-width:2px
    %% ApptSvc (pink)
    linkStyle 8 stroke:#D81B60,stroke-width:2px
    linkStyle 9 stroke:#D81B60,stroke-width:2px
    %% EvtMgmtSvc (orange)
    linkStyle 10 stroke:#FB8C00,stroke-width:2px
    linkStyle 11 stroke:#FB8C00,stroke-width:2px
    %% PolicySvc (amber)
    linkStyle 12 stroke:#FFB300,stroke-width:2px
    %% SearchSvc (green)
    linkStyle 13 stroke:#43A047,stroke-width:2px
    linkStyle 14 stroke:#43A047,stroke-width:2px
    %% OrderSvc (light blue)
    linkStyle 15 stroke:#039BE5,stroke-width:2px
    linkStyle 16 stroke:#039BE5,stroke-width:2px
    %% CheckoutSvc (red)
    linkStyle 17 stroke:#E53935,stroke-width:2px
    linkStyle 18 stroke:#E53935,stroke-width:2px
    linkStyle 19 stroke:#E53935,stroke-width:2px
    linkStyle 20 stroke:#E53935,stroke-width:2px
    %% QueueSvc (purple)
    linkStyle 21 stroke:#8E24AA,stroke-width:2px
    %% LotterySvc (cyan)
    linkStyle 22 stroke:#00ACC1,stroke-width:2px
    %% HistorySvc (light green)
    linkStyle 23 stroke:#7CB342,stroke-width:2px
    %% ReportSvc (blue grey)
    linkStyle 24 stroke:#546E7A,stroke-width:2px

    %% ============================================
    %% APPLY STYLES
    %% ============================================
    %% Service nodes — each colored to match its link color
    style AuthSvc fill:#1E88E5,stroke:#1565C0,color:#fff,font-weight:bold
    style MemberSvc fill:#5E35B1,stroke:#4527A0,color:#fff,font-weight:bold
    style AdminSvc fill:#6D4C41,stroke:#4E342E,color:#fff,font-weight:bold
    style NotifSvc fill:#00897B,stroke:#00695C,color:#fff,font-weight:bold
    style CompanySvc fill:#F4511E,stroke:#D84315,color:#fff,font-weight:bold
    style ApptSvc fill:#D81B60,stroke:#AD1457,color:#fff,font-weight:bold
    style EvtMgmtSvc fill:#FB8C00,stroke:#EF6C00,color:#fff,font-weight:bold
    style PolicySvc fill:#FFB300,stroke:#FF8F00,color:#333,font-weight:bold
    style SearchSvc fill:#43A047,stroke:#2E7D32,color:#fff,font-weight:bold
    style OrderSvc fill:#039BE5,stroke:#0277BD,color:#fff,font-weight:bold
    style CheckoutSvc fill:#E53935,stroke:#C62828,color:#fff,font-weight:bold
    style QueueSvc fill:#8E24AA,stroke:#6A1B9A,color:#fff,font-weight:bold
    style LotterySvc fill:#00ACC1,stroke:#00838F,color:#fff,font-weight:bold
    style HistorySvc fill:#7CB342,stroke:#558B2F,color:#fff,font-weight:bold
    style ReportSvc fill:#546E7A,stroke:#37474F,color:#fff,font-weight:bold
    class PayGw,IssGw,NotifCh port
    class Platform,Member,Company,Event,Zone,Order,PurchRec,VQueue,Lottery aggRoot
    class AppTree,ONode,MNode,VMap,RowE,SeatE,OItem,Notif,QEntry,AToken,LWinner,PItem internal
    class PlatformRepo,MemberRepo,CompanyRepo,EventRepo,ZoneRepo,OrderRepo,QueueRepo,LotteryRepo,PurchaseRepo repo
    class OFactory internal
    class BuyerRef,BuyerSnap,EvtSnap,DiscSnap,MoneyVO valueObj
    class PPol,DPol,DRule policy
    class DBRepos,PayAdapt,IssAdapt,NotifAdapt infra

