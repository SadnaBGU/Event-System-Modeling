    style AGG_MEMBER fill:#C8E6C9,stroke:#2E7D32,stroke-width:2px,stroke-dasharray:5 5
    style AGG_COMPANY fill:#C8E6C9,stroke:#2E7D32,stroke-width:2px,stroke-dasharray:5 5
    style AGG_EVENT fill:#C8E6C9,stroke:#2E7D32,stroke-width:2px,stroke-dasharray:5 5
