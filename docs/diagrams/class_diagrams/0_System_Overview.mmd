    %% ============================================
    style APP fill:#E8F0FE,stroke:#4A90D9,stroke-width:3px,color:#1a3a5c
    style PORTS fill:#FFF3E0,stroke:#F5A623,stroke-width:3px,color:#7a4a00
    style DOMAIN fill:#E8F5E9,stroke:#7ED321,stroke-width:3px,color:#1b5e20
    style INFRA fill:#FFEBEE,stroke:#E07070,stroke-width:3px,color:#7a1a1a
